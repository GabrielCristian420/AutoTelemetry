          <mxGeometry x="500" y="30" width="600" height="40" as="geometry" />
        </mxCell>

        <mxCell id="fleet-manager" value="&lt;b&gt;Fleet Manager&lt;/b&gt;&lt;div&gt;[Person]&lt;/div&gt;&lt;br&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;Views dashboard, monitors vehicles,&lt;br&gt;receives alerts&lt;/font&gt;" style="shape=mxgraph.c4.person2;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#08427B;strokeColor=#073B6F;fontColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="120" y="140" width="200" height="180" as="geometry" />
        </mxCell>

        <mxCell id="driver" value="&lt;b&gt;Driver&lt;/b&gt;&lt;div&gt;[Person]&lt;/div&gt;&lt;br&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;Drives the vehicle, sends telemetry&lt;br&gt;data via mobile app&lt;/font&gt;" style="shape=mxgraph.c4.person2;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#08427B;strokeColor=#073B6F;fontColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="120" y="520" width="200" height="180" as="geometry" />
        </mxCell>

        <mxCell id="platform" value="&lt;b&gt;AutoTelemetry Platform&lt;/b&gt;&lt;div&gt;[Software System]&lt;/div&gt;&lt;br&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;Ingests, stores and analyzes vehicle&lt;br&gt;telemetry data from OBD-II devices&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;labelBackgroundColor=none;fillColor=#1168BD;fontColor=#ffffff;align=center;arcSize=8;strokeColor=#0B4884;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="560" y="340" width="360" height="160" as="geometry" />
        </mxCell>

        <mxCell id="obd-dongle" value="&lt;b&gt;OBD-II Dongle&lt;/b&gt;&lt;div&gt;[External System]&lt;/div&gt;&lt;br&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;Reads sensor data from the vehicle's&lt;br&gt;ECU via Bluetooth&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;labelBackgroundColor=none;fillColor=#999999;fontColor=#ffffff;align=center;arcSize=8;strokeColor=#8A8A8A;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1080" y="140" width="300" height="140" as="geometry" />
        </mxCell>

