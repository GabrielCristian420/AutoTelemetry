        <mxCell id="e-dongle-driver" value="Streams sensor data&lt;br&gt;[Bluetooth]" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#333333;fontSize=11;fontColor=#1a1a1a;labelBackgroundColor=#ffffff;labelBorderColor=#cccccc;" edge="1" parent="1" source="obd-dongle" target="driver">
