        </mxCell>

        <!-- ========== ARROWS: Event Consumer → Live Telemetry Service ========== -->
        <mxCell id="e-consumer-live" value="Feeds buffer" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;endArrow=open;endFill=0;strokeColor=#333333;strokeWidth=1;fontSize=10;fontColor=#1a1a1a;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="event-consumer" target="live-svc">
